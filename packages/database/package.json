{
  "name": "@hardware-pos/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma schema, generated client, and database access for Hardware POS (PostgreSQL).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:format": "prisma format",
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(no linter configured for @hardware-pos/database yet)\"",
    "clean": "rm -rf dist node_modules/.prisma *.tsbuildinfo"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "typescript": "^5.6.3"
  }
}
