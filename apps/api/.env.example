# Hardware POS API environment
NODE_ENV=development

# HTTP port the NestJS server listens on
API_PORT=4000

# PostgreSQL connection string (consumed via @hardware-pos/database / Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hardware_pos?schema=public"

# Allowed CORS origin for the web front-end
WEB_ORIGIN=http://localhost:3000

# Auth — secret used to sign session JWTs (required). Use a long random value.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=12h

# ── Upload storage ──
# 'local' (default): files under <cwd>/uploads on the API server, served at /uploads.
# 's3': AWS S3 or an S3-compatible endpoint (LocalStack, MinIO). For the bundled
# LocalStack service (docker-compose): uncomment everything below as-is, then
# create the bucket once inside the container:
#   awslocal s3 mb s3://hardware-pos-uploads
# STORAGE_PROVIDER=s3
# S3_BUCKET=hardware-pos-uploads
# S3_REGION=us-east-1
# Use 127.0.0.1 (not localhost): Node resolves localhost to ::1, which rootless
# container port-forwarding accepts and then resets.
# S3_ENDPOINT=http://127.0.0.1:4566
# S3_ACCESS_KEY_ID=test
# S3_SECRET_ACCESS_KEY=test

# ── QuickBooks Online OAuth 2.0 ──
# Create an app at https://developer.intuit.com and copy the keys here.
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:4000/v1/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=sandbox

# Key used to encrypt stored OAuth tokens at rest (required for QuickBooks).
TOKEN_ENCRYPTION_KEY=change-me-32-byte-random-secret
